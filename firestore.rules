rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Users collection rules
    match /users/{walletAddress} {
      allow read, delete: if true;
      allow create: if request.resource.data.wallet_address != null 
                    && request.resource.data.wallet_address == walletAddress;
      allow update: if request.resource.data.wallet_address == resource.data.wallet_address
                    && walletAddress == resource.id;
    }

    // 2. Tasks collection rules
    match /tasks/{taskId} {
      allow read, delete: if true;
      allow create: if (request.resource.data.created_by_wallet != null
                    && request.resource.data.transaction_hash != null)
                    || request.resource.data.created_by_wallet == 'system';
      allow update: if 
                    // Prevent editing completed, expired, or refunded tasks unless reopening or refunding
                    (
                      (resource.data.status != 'completed' && resource.data.status != 'expired' && resource.data.status != 'refunded')
                      ||
                      (request.resource.data.status == 'refunded' && resource.data.status == 'expired')
                      ||
                      (request.resource.data.status == 'active' && (resource.data.status == 'completed' || resource.data.status == 'expired' || resource.data.status == 'refunded'))
                    )
                    // Prevent overwriting the transaction hash unless reopening the task
                    && (
                      !('transaction_hash' in resource.data) || 
                      request.resource.data.transaction_hash == resource.data.transaction_hash || 
                      (request.resource.data.status == 'active' && (resource.data.status == 'completed' || resource.data.status == 'expired' || resource.data.status == 'refunded'))
                    )
                    // Wallet address must always exist
                    && request.resource.data.created_by_wallet != null;
    }

    // 3. Submissions collection rules
    match /submissions/{submissionId} {
      allow read, delete: if true;
      allow create: if request.resource.data.wallet_address != null
                    && request.resource.data.task_id != null;
      allow update: if
                    // Prevent changing the worker wallet address
                    request.resource.data.wallet_address == resource.data.wallet_address
                    // Users can only edit their own submissions unless they are the task creator reviewing it or the admin resolving disputes
                    && (
                      // Case A: Worker updating their own submission (status must remain same, OR transition from rejected to disputed / pending for resubmission)
                      (
                        request.resource.data.wallet_address == resource.data.wallet_address
                        && (
                          request.resource.data.status == resource.data.status
                          || (resource.data.status == 'rejected' && (request.resource.data.status == 'disputed' || request.resource.data.status == 'pending'))
                        )
                      )
                      ||
                      // Case B: Task Creator reviewing/approving/rejecting
                      (
                        // Verify reviewer wallet matches the task's created_by_wallet
                        request.resource.data.reviewer_wallet == get(/databases/$(database)/documents/tasks/$(resource.data.task_id)).data.created_by_wallet
                      )
                      ||
                      // Case C: Allow system auto-approvals
                      (
                        request.resource.data.reviewer_wallet == 'system-auto-approval'
                      )
                      ||
                      // Case D: Allow platform admin to resolve disputes
                      (
                        request.resource.data.reviewer_wallet == get(/databases/$(database)/documents/admin/stats).data.admin_wallet
                        && resource.data.status == 'disputed'
                      )
                    );
    }

    // 4. Admin collection rules
    match /admin/{adminId} {
      allow read, write: if true;
    }

    // 5. Payments collection rules
    match /payments/{paymentId} {
      allow read, delete: if true;
      allow create: if request.resource.data.wallet_address != null
                    && request.resource.data.task_id != null
                    && request.resource.data.transaction_hash != null;
      allow update: if false; // Payments are historical immutable ledger records
    }

    // 6. Disputes collection rules
    match /disputes/{disputeId} {
      allow read, delete: if true;
      allow create: if request.resource.data.wallet_address != null
                    && request.resource.data.task_id != null;
      allow update: if true; // Allowed for moderation
    }

    // 7. Withdrawals collection rules
    match /withdrawals/{withdrawalId} {
      allow read, write, delete: if true;
    }

    // 8. Notifications subcollection under users
    match /users/{walletAddress}/notifications/{notificationId} {
      allow read: if true;
      allow create: if true;
      allow update: if request.resource.data.read == true;
      allow delete: if false;
    }
  }
}
